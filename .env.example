NODE_ENV=development
PORT=3001
GRPC_PORT=50051

# PostgreSQL
DATABASE_URL=postgresql://products:products_secret@localhost:5432/products_db?schema=public

# Redis (stock reservation TTL)
REDIS_URL=redis://localhost:6379
STOCK_RESERVATION_TTL_SECONDS=900

# Elasticsearch (set ELASTICSEARCH_ENABLED=false on small servers — search uses PostgreSQL)
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=products

# Kafka (set KAFKA_ENABLED=false on small servers — stock release via Kafka disabled)
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=products-service
KAFKA_GROUP_ID=products-service-group
KAFKA_STOCK_RELEASE_TOPIC=stock.release

# Auth Service JWT (RS256 public key — PEM with \n escapes)
PASSPORT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_RSA_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Swagger UI (/api/docs) — disabled automatically when NODE_ENV=production
# Set explicitly: true | false
SWAGGER_ENABLED=true
