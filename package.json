{
  "name": "ecommerce-products-service",
  "version": "1.0.0",
  "description": "E-commerce Products microservice with REST, gRPC, Kafka, Elasticsearch",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && npm run copy:proto && npm run openapi",
    "copy:proto": "node -e \"require('fs').cpSync('src/infrastructure/grpc/proto','dist/infrastructure/grpc/proto',{recursive:true})\"",
    "openapi": "node dist/openapi-generate.js",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint src tests --ext .ts",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "prod:up": "bash scripts/start-production.sh",
    "prod:local": "bash scripts/start-production.sh --local"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
